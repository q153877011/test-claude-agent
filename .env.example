# Claude Agent Starter — Environment Variables
# Copy this file to .env and fill in real values

# ── Option 1: Official Anthropic direct connection (recommended) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_BASE_URL=                   # Optional, leave empty for default
ANTHROPIC_CUSTOM_HEADERS=             # Optional, custom request headers

# ── Option 2: AI Gateway (must be compatible with Anthropic Messages API) ──
AI_GATEWAY_API_KEY=your_gateway_key      # Required
AI_GATEWAY_BASE_URL=https://your-gateway.example.com  # Required
AI_GATEWAY_MODEL=@makers/hy3-preview          # Optional
AI_GATEWAY_SMALL_MODEL=@makers/hy3-preview     # Optional

# ── General config ──
CLAUDE_MODEL=claude-sonnet-4-6        # Optional, override default model
ANTHROPIC_SMALL_FAST_MODEL=           # Optional, override CLI internal small model

# ── Option 3: AI Gateway (current default) ──
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=@makers/hy3-preview
